{
    "module_title": "Strings",
    "problems": [
        {
            "title": "Check Substring Presence",
            "difficulty": "EASY",
            "description": "Given two strings, check if the second string is a substring of the first.\n\nPrint YES if present, otherwise NO.",
            "input_format": "First line contains main string.\nSecond line contains substring.",
            "output_format": "Print YES or NO.",
            "constraints": [
                "1 <= length <= 100000"
            ],
            "sample_tests": [
                {
                    "input": "hello world\nworld",
                    "output": "YES"
                }
            ],
            "test_cases": [
                {
                    "input": "abcdef\ncd",
                    "output": "YES"
                },
                {
                    "input": "abcdef\ngh",
                    "output": "NO"
                },
                {
                    "input": "a\na",
                    "output": "YES"
                },
                {
                    "input": "abc\nabcd",
                    "output": "NO"
                }
            ]
        },
        {
            "title": "Repeat String n Times",
            "difficulty": "EASY",
            "description": "Given a string and an integer n, repeat the string n times.",
            "input_format": "First line contains string.\nSecond line contains integer n.",
            "output_format": "Print repeated string.",
            "constraints": [
                "1 <= length <= 1000"
            ],
            "sample_tests": [
                {
                    "input": "ab\n3",
                    "output": "ababab"
                }
            ],
            "test_cases": [
                {
                    "input": "a\n5",
                    "output": "aaaaa"
                },
                {
                    "input": "xy\n2",
                    "output": "xyxy"
                },
                {
                    "input": "z\n1",
                    "output": "z"
                },
                {
                    "input": "hi\n0",
                    "output": ""
                }
            ]
        },
        {
            "title": "Find Middle Character",
            "difficulty": "EASY",
            "description": "Given a string, print the middle character.\n\nIf length is even, print the left middle.",
            "input_format": "Single line containing a string.",
            "output_format": "Print middle character.",
            "constraints": [
                "1 <= length <= 100000"
            ],
            "sample_tests": [
                {
                    "input": "hello",
                    "output": "l"
                }
            ],
            "test_cases": [
                {
                    "input": "abcd",
                    "output": "b"
                },
                {
                    "input": "a",
                    "output": "a"
                },
                {
                    "input": "xyz",
                    "output": "y"
                },
                {
                    "input": "java",
                    "output": "a"
                }
            ]
        },
        {
            "title": "Swap First and Last Character",
            "difficulty": "EASY",
            "description": "Given a string, swap its first and last characters.",
            "input_format": "Single line containing a string.",
            "output_format": "Print modified string.",
            "constraints": [
                "1 <= length <= 100000"
            ],
            "sample_tests": [
                {
                    "input": "hello",
                    "output": "oellh"
                }
            ],
            "test_cases": [
                {
                    "input": "ab",
                    "output": "ba"
                },
                {
                    "input": "a",
                    "output": "a"
                },
                {
                    "input": "world",
                    "output": "dorlw"
                },
                {
                    "input": "xy",
                    "output": "yx"
                }
            ]
        },
        {
            "title": "Remove First Occurrence of Character",
            "difficulty": "EASY",
            "description": "Given a string and a character, remove the first occurrence of that character.",
            "input_format": "First line contains string.\nSecond line contains character.",
            "output_format": "Print modified string.",
            "constraints": [
                "1 <= length <= 100000"
            ],
            "sample_tests": [
                {
                    "input": "hello\nl",
                    "output": "helo"
                }
            ],
            "test_cases": [
                {
                    "input": "banana\na",
                    "output": "bnana"
                },
                {
                    "input": "abc\nd",
                    "output": "abc"
                },
                {
                    "input": "a\na",
                    "output": ""
                },
                {
                    "input": "mississippi\ns",
                    "output": "miissippi"
                }
            ]
        }
    ]
}